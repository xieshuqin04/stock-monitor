{
  "version": 2,
  "public": true,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/stock/main-inflow", "destination": "/api/stock/main-inflow.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ]
}
